{
  "name": "cambium",
  "version": "0.2.5",
  "codename": "Thalia .5",
  "private": true,
  "type": "module",
  "description": "The composition layer for the constellation — registry + pipeline + the dry-run conductor.",
  "scripts": {
    "test": "node --test 'bin/*.test.mjs' 'bin/operator/*.test.ts' 'bin/operator/onboarding/*.test.ts' 'bin/operator/quests/*.test.ts' 'bin/operator/skills/*.test.ts' 'bin/operator/narrative/*.test.ts' 'bin/quine/hyphae/*.test.ts' 'workers/quests/src/*.test.ts'",
    "operator": "node bin/operator/cli.ts",
    "quine": "node bin/quine/quine.ts",
    "plan": "node bin/compose.mjs plan",
    "validate": "node bin/compose.mjs validate",
    "render-docs": "node bin/render-docs.mjs",
    "render-docs:check": "node bin/render-docs.mjs --check",
    "standalone:audit": "node scripts/standalone-audit.mjs",
    "standalone:smoke": "node scripts/standalone-smoke.mjs",
    "demo:tenant": "node scripts/demo-tenant-fixture.mjs",
    "demo:quests": "node scripts/demo-quest-ledger.mjs",
    "tapestry:snapshot": "node scripts/tapestry-snapshot.mjs",
    "r3f:dev": "npm --prefix apps/cambium-r3f run dev",
    "r3f:build": "npm --prefix apps/cambium-r3f run build",
    "r3f:test": "npm --prefix apps/cambium-r3f run test",
    "r3f:sync": "npm --prefix apps/cambium-r3f run sync:contracts",
    "r3f:meshy": "npm --prefix apps/cambium-r3f run meshy:assets --",
    "r3f:meshy:image": "npm --prefix apps/cambium-r3f run meshy:image-to-3d --",
    "r3f:source-plates": "npm --prefix apps/cambium-r3f run source-plates --"
  }
}
